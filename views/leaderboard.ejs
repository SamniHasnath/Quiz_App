<!DOCTYPE html>
<html>
<head>
  <title>Leaderboard</title>
  <link rel="stylesheet" href="/style.css">
</head>

<body>
  <div class="container">
    <div class="card">

      <h1>🏆 Leaderboard</h1>

      <table>
        <tr>
          <th>User</th>
          <th>Score</th>
        </tr>

        <% leaders.forEach(l => { %>
          <tr>
            <td><%= l.username %></td>
            <td><%= l.score %></td>
          </tr>
        <% }) %>

      </table>

      <a href="/">Back to Quiz</a>

    </div>
  </div>
</body>
</html>